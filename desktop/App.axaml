<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             xmlns:pages="clr-namespace:PortableCncApp.Views.Pages"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="PortableCncApp.App"
             RequestedThemeVariant="Default">

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />

        <!-- Global control baselines -->
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Slider">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Layout primitives -->
        <Style Selector="Border.PanelCard">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="Border.PanelCard.Loose">
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Border.InsetSurface">
            <Setter Property="Background" Value="{DynamicResource InsetSurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style Selector="Border.InsetSurface.Subtle">
            <Setter Property="Background" Value="{DynamicResource InsetSurfaceSubtleBrush}"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="Border.InsetSurface.Code">
            <Setter Property="Background" Value="{DynamicResource CodeSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Border.StatusPill">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <!-- Typography primitives -->
        <Style Selector="TextBlock.PanelTitle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Setter Property="LetterSpacing" Value="1"/>
        </Style>
        <Style Selector="TextBlock.SectionHeading">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel.Muted">
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.FieldValue">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.PillText">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.Caption">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.CodeValue">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.CodeValue.Muted">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.ReadoutValue">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.ReadoutValue.Muted">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.CodeText">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>

        <!-- App button system -->
        <Style Selector="Button.AppButton">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="Button.AppButton.Primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.AppButton.Success">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.AppButton.Warning">
            <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.AppButton.Danger">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ToggleButton.AppButton">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>

        <!-- Legacy shell button styles kept for compatibility -->
        <Style Selector="Button.NavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="Button.NavButton TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavButtonHoverBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pointerover TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavButtonPressedBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pressed">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pressed TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton.active">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.NavButton.active /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.NavButton.active TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton.active:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
        <Style Selector="Button.NavButton.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.NavButton.active:pointerover TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton.active:pressed">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
        <Style Selector="Button.NavButton.active:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.NavButton.active:pressed TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        
        <!-- Control Button Styles -->
        <Style Selector="Button.ControlButton">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.ControlButton.Success">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
        </Style>
        <Style Selector="Button.ControlButton.Warning">
            <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
        </Style>
        <Style Selector="Button.ControlButton.Danger">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        </Style>
        
        <!-- Jog Button Styles -->
        <Style Selector="Button.JogButton">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.JogButton.XAxis">
            <Setter Property="Background" Value="#E06666"/>
        </Style>
        <Style Selector="Button.JogButton.YAxis">
            <Setter Property="Background" Value="#93C47D"/>
        </Style>
        <Style Selector="Button.JogButton.ZAxis">
            <Setter Property="Background" Value="#6FA8DC"/>
        </Style>
        
        <!-- Step Button Styles -->
        <Style Selector="Button.StepButton">
            <Setter Property="Background" Value="{DynamicResource StepButtonBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="Button.StepButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource StepButtonHoverBrush}"/>
        </Style>
        <Style Selector="FlyoutPresenter.CompactFlyout">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F5F8"/>
                    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F7F9FC"/>
                    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#F7F9FC"/>
                    <SolidColorBrush x:Key="BorderBrush" Color="#D4DAE2"/>

                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#18202A"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#52606D"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#7A8794"/>

                    <SolidColorBrush x:Key="InsetSurfaceBrush" Color="#EEF2F6"/>
                    <SolidColorBrush x:Key="InsetSurfaceSubtleBrush" Color="#F7F9FB"/>
                    <SolidColorBrush x:Key="CodeSurfaceBrush" Color="#F5F7FA"/>
                    <SolidColorBrush x:Key="NavButtonHoverBrush" Color="#E6ECF3"/>
                    <SolidColorBrush x:Key="NavButtonPressedBrush" Color="#DCE4EE"/>
                    <SolidColorBrush x:Key="StepButtonBrush" Color="#E8EDF3"/>
                    <SolidColorBrush x:Key="StepButtonHoverBrush" Color="#DCE4EE"/>

                    <SolidColorBrush x:Key="ViewerBackgroundBrush" Color="#E9EEF4"/>
                    <SolidColorBrush x:Key="FileCardBrush" Color="#F7F9FB"/>
                    <SolidColorBrush x:Key="FileSizeBadgeBrush" Color="#E6ECF3"/>
                    <SolidColorBrush x:Key="FlyoutSurfaceBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="ConsoleSurfaceBrush" Color="#F5F7FA"/>
                    <SolidColorBrush x:Key="SelectionBorderBrush" Color="#C5CDD6"/>

                    <SolidColorBrush x:Key="ConnectInfoSurfaceBrush" Color="#EAF3FF"/>
                    <SolidColorBrush x:Key="ConnectInfoBorderBrush" Color="#8EB7E6"/>
                    <SolidColorBrush x:Key="ConnectingSurfaceBrush" Color="#FFF7E1"/>
                    <SolidColorBrush x:Key="ConnectingBorderBrush" Color="#D8B760"/>

                    <SolidColorBrush x:Key="StageNeutralBackgroundBrush" Color="#F3F5F8"/>
                    <SolidColorBrush x:Key="StageNeutralBorderBrush" Color="#D4DAE2"/>
                    <SolidColorBrush x:Key="StageSuccessBackgroundBrush" Color="#E8F6EE"/>
                    <SolidColorBrush x:Key="StageWarningBackgroundBrush" Color="#FFF3D6"/>
                    <SolidColorBrush x:Key="StageDangerBackgroundBrush" Color="#FDEAEA"/>

                    <SolidColorBrush x:Key="WarningHighlightBrush" Color="#FFF1CC"/>
                    <SolidColorBrush x:Key="WarningLineForegroundBrush" Color="#7A5600"/>
                    <SolidColorBrush x:Key="NeutralIndicatorBrush" Color="#C5CDD6"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#242424"/>
                    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1E1E1E"/>
                    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#1E1E1E"/>
                    <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>

                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#666666"/>

                    <SolidColorBrush x:Key="InsetSurfaceBrush" Color="#2A2A2A"/>
                    <SolidColorBrush x:Key="InsetSurfaceSubtleBrush" Color="#1F1F1F"/>
                    <SolidColorBrush x:Key="CodeSurfaceBrush" Color="#171717"/>
                    <SolidColorBrush x:Key="NavButtonHoverBrush" Color="#2A2A2A"/>
                    <SolidColorBrush x:Key="NavButtonPressedBrush" Color="#333333"/>
                    <SolidColorBrush x:Key="StepButtonBrush" Color="#3A3A3A"/>
                    <SolidColorBrush x:Key="StepButtonHoverBrush" Color="#4A4A4A"/>

                    <SolidColorBrush x:Key="ViewerBackgroundBrush" Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="FileCardBrush" Color="#272727"/>
                    <SolidColorBrush x:Key="FileSizeBadgeBrush" Color="#313131"/>
                    <SolidColorBrush x:Key="FlyoutSurfaceBrush" Color="#1F1F1F"/>
                    <SolidColorBrush x:Key="ConsoleSurfaceBrush" Color="#0D0D0D"/>
                    <SolidColorBrush x:Key="SelectionBorderBrush" Color="#3A3A3A"/>

                    <SolidColorBrush x:Key="ConnectInfoSurfaceBrush" Color="#1E2732"/>
                    <SolidColorBrush x:Key="ConnectInfoBorderBrush" Color="#35506B"/>
                    <SolidColorBrush x:Key="ConnectingSurfaceBrush" Color="#35280F"/>
                    <SolidColorBrush x:Key="ConnectingBorderBrush" Color="#6E5421"/>

                    <SolidColorBrush x:Key="StageNeutralBackgroundBrush" Color="#252525"/>
                    <SolidColorBrush x:Key="StageNeutralBorderBrush" Color="#333333"/>
                    <SolidColorBrush x:Key="StageSuccessBackgroundBrush" Color="#1F3A2A"/>
                    <SolidColorBrush x:Key="StageWarningBackgroundBrush" Color="#4A390B"/>
                    <SolidColorBrush x:Key="StageDangerBackgroundBrush" Color="#4A1616"/>

                    <SolidColorBrush x:Key="WarningHighlightBrush" Color="#3A2A14"/>
                    <SolidColorBrush x:Key="WarningLineForegroundBrush" Color="#FFD27A"/>
                    <SolidColorBrush x:Key="NeutralIndicatorBrush" Color="#444444"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="AccentBrush" Color="#4A9EFF"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#D83B3B"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#3BB273"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#E0A100"/>
            <SolidColorBrush x:Key="InfoBrush" Color="#5B9BD5"/>
            <SolidColorBrush x:Key="NeutralStateBrush" Color="#808080"/>

            <Thickness x:Key="PagePadding">20</Thickness>
        </ResourceDictionary>
    </Application.Resources>

    <!-- DataTemplates for page navigation -->
    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <pages:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ManualControlViewModel}">
            <pages:ManualControlView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FilesViewModel}">
            <pages:FilesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConnectViewModel}">
            <pages:ConnectView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <pages:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiagnosticsViewModel}">
            <pages:DiagnosticsView/>
        </DataTemplate>
    </Application.DataTemplates>

</Application>
