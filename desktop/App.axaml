<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             xmlns:pages="clr-namespace:PortableCncApp.Views.Pages"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="PortableCncApp.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />

        <!-- Global control baselines -->
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Slider">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Layout primitives -->
        <Style Selector="Border.PanelCard">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="Border.PanelCard.Loose">
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Border.InsetSurface">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style Selector="Border.InsetSurface.Subtle">
            <Setter Property="Background" Value="#1F1F1F"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="Border.InsetSurface.Code">
            <Setter Property="Background" Value="#171717"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Border.StatusPill">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <!-- Typography primitives -->
        <Style Selector="TextBlock.PanelTitle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Setter Property="LetterSpacing" Value="1"/>
        </Style>
        <Style Selector="TextBlock.SectionHeading">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel.Muted">
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.FieldValue">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.PillText">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.Caption">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.CodeValue">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.CodeValue.Muted">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.ReadoutValue">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.ReadoutValue.Muted">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.CodeText">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>

        <!-- App button system -->
        <Style Selector="Button.AppButton">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="Button.AppButton.Primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.AppButton.Success">
            <Setter Property="Background" Value="#3BB273"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.AppButton.Warning">
            <Setter Property="Background" Value="#E0A100"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.AppButton.Danger">
            <Setter Property="Background" Value="#D83B3B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ToggleButton.AppButton">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>

        <!-- Legacy shell button styles kept for compatibility -->
        <Style Selector="Button.NavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="Button.NavButton TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A"/>
        </Style>
        <Style Selector="Button.NavButton:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pointerover TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#333333"/>
        </Style>
        <Style Selector="Button.NavButton:pressed">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton:pressed TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton.active">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.NavButton.active /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.NavButton.active TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton.active:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
        <Style Selector="Button.NavButton.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.NavButton.active:pointerover TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.NavButton.active:pressed">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
        <Style Selector="Button.NavButton.active:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.NavButton.active:pressed TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        
        <!-- Control Button Styles -->
        <Style Selector="Button.ControlButton">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.ControlButton.Success">
            <Setter Property="Background" Value="#3BB273"/>
        </Style>
        <Style Selector="Button.ControlButton.Warning">
            <Setter Property="Background" Value="#E0A100"/>
        </Style>
        <Style Selector="Button.ControlButton.Danger">
            <Setter Property="Background" Value="#D83B3B"/>
        </Style>
        
        <!-- Jog Button Styles -->
        <Style Selector="Button.JogButton">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.JogButton.XAxis">
            <Setter Property="Background" Value="#E06666"/>
        </Style>
        <Style Selector="Button.JogButton.YAxis">
            <Setter Property="Background" Value="#93C47D"/>
        </Style>
        <Style Selector="Button.JogButton.ZAxis">
            <Setter Property="Background" Value="#6FA8DC"/>
        </Style>
        
        <!-- Step Button Styles -->
        <Style Selector="Button.StepButton">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="Button.StepButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A4A4A"/>
        </Style>
    </Application.Styles>

    <Application.Resources>
        <!-- Color Palette -->
        <Color x:Key="AppBackgroundColor">#1A1A1A</Color>
        <Color x:Key="PanelBackgroundColor">#242424</Color>
        <Color x:Key="SidebarBackgroundColor">#1E1E1E</Color>
        <Color x:Key="HeaderBackgroundColor">#1E1E1E</Color>
        <Color x:Key="BorderColor">#333333</Color>
        
        <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
        <Color x:Key="TextSecondaryColor">#A0A0A0</Color>
        <Color x:Key="TextTertiaryColor">#666666</Color>
        
        <Color x:Key="AccentColor">#4A9EFF</Color>
        <Color x:Key="DangerColor">#D83B3B</Color>
        <Color x:Key="SuccessColor">#3BB273</Color>
        <Color x:Key="WarningColor">#E0A100</Color>
        
        <!-- Brushes -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackgroundColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
        
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
        
        <!-- Thickness -->
        <Thickness x:Key="PagePadding">20</Thickness>
    </Application.Resources>

    <!-- DataTemplates for page navigation -->
    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <pages:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ManualControlViewModel}">
            <pages:ManualControlView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FilesViewModel}">
            <pages:FilesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConnectViewModel}">
            <pages:ConnectView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <pages:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiagnosticsViewModel}">
            <pages:DiagnosticsView/>
        </DataTemplate>
    </Application.DataTemplates>

</Application>
