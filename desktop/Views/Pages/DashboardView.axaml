<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PortableCncApp.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             x:Class="PortableCncApp.Views.Pages.DashboardView"
             x:DataType="vm:DashboardViewModel"
             mc:Ignorable="d">

  <Grid>

    <!-- Main Content Grid -->
    <Grid Grid.Row="0" ColumnDefinitions="*,320">
      
      <!-- LEFT: G-code Visualization Area -->
      <Border Background="{DynamicResource PanelBackgroundBrush}"
              CornerRadius="4"
              Padding="8"
              Margin="0,0,8,0">
        <DockPanel>
          <!-- Header row with title and toggle -->
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <StackPanel>
              <TextBlock Text="{Binding ViewerTitle}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         LetterSpacing="1"/>
              <TextBlock Text="{Binding ViewerHint}"
                         FontSize="11"
                         Margin="0,4,0,0"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <ToggleButton x:Name="ViewerPanelToggle"
                          Grid.Column="1"
                          Content="Viewer"
                          IsChecked="{Binding IsViewerPanelOpen, Mode=TwoWay}"
                          IsEnabled="{Binding HasLoadedToolpath}"
                          VerticalAlignment="Center"
                          Padding="8,4"
                          FontSize="11"/>
          </Grid>

          <!-- Collapsible viewer controls (docked bottom, before WebView so it sits below it) -->
          <Border DockPanel.Dock="Bottom"
                  IsVisible="{Binding IsViewerPanelOpen}"
                  Background="{DynamicResource PanelBackgroundBrush}"
                  CornerRadius="4"
                  Padding="8"
                  Margin="0,8,0,0"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto">
                <CheckBox Content="Rapids"
                          IsChecked="{Binding ShowRapids}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <CheckBox Grid.Column="1"
                          Content="Cuts"
                          IsChecked="{Binding ShowCuts}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <CheckBox Grid.Column="2"
                          Content="Arcs"
                          IsChecked="{Binding ShowArcs}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <CheckBox Grid.Column="3"
                          Content="Plunges"
                          IsChecked="{Binding ShowPlunges}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <CheckBox Grid.Row="1"
                          Content="Completed"
                          IsChecked="{Binding ShowCompletedPath}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <CheckBox Grid.Row="1" Grid.Column="1"
                          Content="Remaining"
                          IsChecked="{Binding ShowRemainingPath}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <CheckBox Grid.Row="1" Grid.Column="2"
                          Content="Stock Box"
                          IsChecked="{Binding ShowStockBox}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Text="SCRUBBER"
                             FontSize="10"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             LetterSpacing="1"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding ScrubberLabel}"
                             FontSize="11"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Grid>
              <Slider Minimum="0"
                      Maximum="{Binding MainVm.ActiveGCodeDocument.TotalLines, TargetNullValue=1}"
                      Value="{Binding ScrubberValue, Mode=TwoWay}"/>
            </StackPanel>
          </Border>

          <!-- 3D viewer -->
          <Border Background="#1A1A1A"
                  IsEnabled="{Binding HasLoadedToolpath}"
                  CornerRadius="4"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <controls:WebToolpathView Document="{Binding MainVm.ActiveGCodeDocument}"
                                      CurrentLine="{Binding PreviewLine}"
                                      PositionX="{Binding MainVm.WorkX}"
                                      PositionY="{Binding MainVm.WorkY}"
                                      PositionZ="{Binding MainVm.WorkZ}"
                                      CameraPreset="{Binding CameraPreset}"
                                      ResetViewToken="{Binding ResetViewToken}"
                                      ShowRapids="{Binding ShowRapids}"
                                      ShowCuts="{Binding ShowCuts}"
                                      ShowArcs="{Binding ShowArcs}"
                                      ShowPlunges="{Binding ShowPlunges}"
                                      ShowCompletedPath="{Binding ShowCompletedPath}"
                                      ShowRemainingPath="{Binding ShowRemainingPath}"
                                      ShowStockBox="{Binding ShowStockBox}"/>
          </Border>
        </DockPanel>
      </Border>

      <!-- RIGHT: Info Panels -->
      <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="8">
        
        <!-- Coordinate Panel -->
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="4"
                Padding="8">
          <StackPanel>
            <TextBlock Text="COORDINATES"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"
                       Margin="0,0,0,8"/>

            <Grid ColumnDefinitions="72,*"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="8">
              <TextBlock Text="Work"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center"/>
              <Border Grid.Column="1"
                      Background="#2A2A2A"
                      CornerRadius="4"
                      Padding="10,6">
                <TextBlock Text="{Binding MainVm.WorkCoordinatesText}"
                           FontSize="19"
                           FontWeight="SemiBold"
                           FontFamily="Consolas"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
              </Border>

              <TextBlock Grid.Row="1"
                         Text="Machine"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center"/>
              <Border Grid.Row="1"
                      Grid.Column="1"
                      Background="#2A2A2A"
                      CornerRadius="4"
                      Padding="10,6">
                <TextBlock Text="{Binding MainVm.MachineCoordinatesText}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
              </Border>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Spindle & Feed Panel -->
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="4"
                Padding="8">
          <StackPanel>
            <TextBlock Text="SPINDLE &amp; FEED"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"
                       Margin="0,0,0,8"/>
            
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
              <StackPanel Margin="0,0,8,8">
                <TextBlock Text="Spindle" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.SpindleSpeed, StringFormat={}{0:F0} RPM}"
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0,0,8">
                <TextBlock Text="Feed Rate" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.FeedRate, StringFormat={}{0:F0} mm/min}"
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              
              <StackPanel Grid.Row="1" Margin="0,0,8,0">
                <TextBlock Text="Feed Override" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.FeedOverride, StringFormat={}{0}%}"
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Environment Panel -->
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="4"
                Padding="8">
          <StackPanel>
            <TextBlock Text="ENVIRONMENT"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"
                       Margin="0,0,0,8"/>
            
            <Grid ColumnDefinitions="*,*">
              <StackPanel>
                <TextBlock Text="Temperature" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.Temperature, StringFormat={}{0:F1}°C}"
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="Humidity" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.Humidity, StringFormat={}{0:F0}%}"
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Program Info Panel -->
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="4"
                Padding="8">
          <StackPanel>
            <TextBlock Text="PROGRAM"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="{Binding MainVm.CurrentFileName, TargetNullValue='No file loaded'}"
                       FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"/>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" Margin="0,12,0,4">
              <StackPanel Margin="0,0,8,8">
                <TextBlock Text="Bounds" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.ActiveToolpathBounds}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0,0,8">
                <TextBlock Text="Depth" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.ActiveToolpathDepth}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Row="1" Margin="0,0,8,0">
                <TextBlock Text="Segments" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.ActiveToolpathSegmentCount}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Grid>
            
            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,4">
              <TextBlock Text="Progress" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock Grid.Column="1" 
                         Text="{Binding MainVm.Progress, StringFormat={}{0:F1}%}"
                         FontSize="11" 
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>
            
            <ProgressBar Value="{Binding MainVm.Progress}" 
                         Maximum="100"
                         Height="8"
                         CornerRadius="4"/>
            
            <TextBlock Text="{Binding MainVm.CurrentLine, StringFormat=Line {0}}"
                       FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="0,8,0,0"/>
          </StackPanel>
        </Border>

      </StackPanel>
      </ScrollViewer>
    </Grid>

  </Grid>
</UserControl>
