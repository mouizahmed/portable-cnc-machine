<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PortableCncApp.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             x:Class="PortableCncApp.Views.Pages.DashboardView"
             x:DataType="vm:DashboardViewModel"
             mc:Ignorable="d">

  <Grid RowDefinitions="*,Auto">
    
    <!-- Main Content Grid -->
    <Grid Grid.Row="0" ColumnDefinitions="*,320">
      
      <!-- LEFT: G-code Visualization Area -->
      <Border Background="{DynamicResource PanelBackgroundBrush}"
              CornerRadius="8"
              Padding="16"
              Margin="0,0,16,0">
        <DockPanel>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <StackPanel>
            <TextBlock Text="{Binding ViewerTitle}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ViewerHint}"
                       FontSize="11"
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
              <TextBlock Text="{Binding MainVm.ActiveToolpathWarnings}"
                         FontSize="11"
                         HorizontalAlignment="Right"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock Text="{Binding MainVm.ActiveToolpathUnits, StringFormat=Display units: {0}}"
                         FontSize="11"
                         HorizontalAlignment="Right"
                         Margin="0,6,0,0"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
              <Button Content="{Binding ViewModeButtonLabel}"
                      Command="{Binding ToggleViewModeCommand}"
                      Margin="0,8,0,0"
                      Padding="10,6"/>
            </StackPanel>
          </Grid>

          <StackPanel DockPanel.Dock="Top"
                      Orientation="Horizontal"
                      Spacing="8"
                      Margin="0,0,0,12">
            <Button Content="Top"
                    Command="{Binding SetCameraPresetCommand}"
                    CommandParameter="Top"
                    Padding="10,6"/>
            <Button Content="Front"
                    Command="{Binding SetCameraPresetCommand}"
                    CommandParameter="Front"
                    Padding="10,6"/>
            <Button Content="Right"
                    Command="{Binding SetCameraPresetCommand}"
                    CommandParameter="Right"
                    Padding="10,6"/>
            <Button Content="Iso"
                    Command="{Binding SetCameraPresetCommand}"
                    CommandParameter="Iso"
                    Padding="10,6"/>
            <Button Content="Reset"
                    Command="{Binding ResetViewCommand}"
                    Padding="10,6"/>
          </StackPanel>
          
          <Border Background="#1A1A1A"
                  CornerRadius="4"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <controls:ToolpathView Document="{Binding MainVm.ActiveGCodeDocument}"
                                   CurrentLine="{Binding PreviewLine}"
                                   PositionX="{Binding MainVm.PositionX}"
                                   PositionY="{Binding MainVm.PositionY}"
                                   PositionZ="{Binding MainVm.PositionZ}"
                                   Is3DView="{Binding Show3DView}"
                                   CameraPreset="{Binding CameraPreset}"
                                   ResetViewToken="{Binding ResetViewToken}"
                                   ShowRapids="{Binding ShowRapids}"
                                   ShowCuts="{Binding ShowCuts}"
                                   ShowArcs="{Binding ShowArcs}"
                                   ShowPlunges="{Binding ShowPlunges}"
                                   ShowCompletedPath="{Binding ShowCompletedPath}"
                                   ShowRemainingPath="{Binding ShowRemainingPath}"
                                   ShowStockBox="{Binding ShowStockBox}"/>
          </Border>
        </DockPanel>
      </Border>

      <!-- RIGHT: Info Panels -->
      <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        
        <!-- DRO Panel -->
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="8"
                Padding="16">
          <StackPanel>
            <TextBlock Text="DIGITAL READOUT"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"
                       Margin="0,0,0,12"/>
            
            <Grid ColumnDefinitions="40,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,8">
              <!-- X -->
              <Border Grid.Row="0" Background="#E06666" CornerRadius="4" Padding="8,4" Margin="0,0,0,8" VerticalAlignment="Stretch">
                <TextBlock Text="X" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <Border Grid.Row="0" Grid.Column="1" Background="#2A2A2A" CornerRadius="4" Padding="12,8" Margin="8,0,0,8">
                <TextBlock Text="{Binding MainVm.PositionX, StringFormat={}{0:F3}}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           FontFamily="Consolas"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
              </Border>
              
              <!-- Y -->
              <Border Grid.Row="1" Background="#93C47D" CornerRadius="4" Padding="8,4" Margin="0,0,0,8" VerticalAlignment="Stretch">
                <TextBlock Text="Y" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <Border Grid.Row="1" Grid.Column="1" Background="#2A2A2A" CornerRadius="4" Padding="12,8" Margin="8,0,0,8">
                <TextBlock Text="{Binding MainVm.PositionY, StringFormat={}{0:F3}}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           FontFamily="Consolas"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
              </Border>
              
              <!-- Z -->
              <Border Grid.Row="2" Background="#6FA8DC" CornerRadius="4" Padding="8,4" VerticalAlignment="Stretch">
                <TextBlock Text="Z" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <Border Grid.Row="2" Grid.Column="1" Background="#2A2A2A" CornerRadius="4" Padding="12,8" Margin="8,0,0,0">
                <TextBlock Text="{Binding MainVm.PositionZ, StringFormat={}{0:F3}}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           FontFamily="Consolas"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
              </Border>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Spindle & Feed Panel -->
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="8"
                Padding="16">
          <StackPanel>
            <TextBlock Text="SPINDLE &amp; FEED"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"
                       Margin="0,0,0,12"/>
            
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
              <StackPanel Margin="0,0,8,8">
                <TextBlock Text="Spindle" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.SpindleSpeed, StringFormat={}{0:F0} RPM}"
                           FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0,0,8">
                <TextBlock Text="Feed Rate" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.FeedRate, StringFormat={}{0:F0} mm/min}"
                           FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              
              <StackPanel Grid.Row="1" Margin="0,0,8,0">
                <TextBlock Text="Feed Override" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.FeedOverride, StringFormat={}{0}%}"
                           FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Environment Panel -->
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="8"
                Padding="16">
          <StackPanel>
            <TextBlock Text="ENVIRONMENT"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"
                       Margin="0,0,0,12"/>
            
            <Grid ColumnDefinitions="*,*">
              <StackPanel>
                <TextBlock Text="Temperature" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.Temperature, StringFormat={}{0:F1}°C}"
                           FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="Humidity" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.Humidity, StringFormat={}{0:F0}%}"
                           FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Program Info Panel -->
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="8"
                Padding="16">
          <StackPanel>
            <TextBlock Text="PROGRAM"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"
                       Margin="0,0,0,12"/>
            
            <TextBlock Text="{Binding MainVm.CurrentFileName, TargetNullValue='No file loaded'}"
                       FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"/>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" Margin="0,12,0,4">
              <StackPanel Margin="0,0,8,8">
                <TextBlock Text="Bounds" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.ActiveToolpathBounds}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0,0,8">
                <TextBlock Text="Depth" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.ActiveToolpathDepth}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
              <StackPanel Grid.Row="1" Margin="0,0,8,0">
                <TextBlock Text="Segments" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding MainVm.ActiveToolpathSegmentCount}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Grid>
            
            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,4">
              <TextBlock Text="Progress" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock Grid.Column="1" 
                         Text="{Binding MainVm.Progress, StringFormat={}{0:F1}%}"
                         FontSize="11" 
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>
            
            <ProgressBar Value="{Binding MainVm.Progress}" 
                         Maximum="100"
                         Height="8"
                         CornerRadius="4"/>
            
            <TextBlock Text="{Binding MainVm.CurrentLine, StringFormat=Line {0}}"
                       FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="0,8,0,0"/>
          </StackPanel>
        </Border>

        <!-- Viewer Controls -->
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="8"
                Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="VIEWER"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"/>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
              <CheckBox Content="Rapids"
                        IsChecked="{Binding ShowRapids}"
                        Foreground="{DynamicResource TextPrimaryBrush}"/>
              <CheckBox Grid.Column="1"
                        Content="Cuts"
                        IsChecked="{Binding ShowCuts}"
                        Foreground="{DynamicResource TextPrimaryBrush}"/>
              <CheckBox Grid.Row="1"
                        Content="Arcs"
                        IsChecked="{Binding ShowArcs}"
                        Foreground="{DynamicResource TextPrimaryBrush}"/>
              <CheckBox Grid.Row="1"
                        Grid.Column="1"
                        Content="Plunges"
                        IsChecked="{Binding ShowPlunges}"
                        Foreground="{DynamicResource TextPrimaryBrush}"/>
              <CheckBox Grid.Row="2"
                        Content="Completed"
                        IsChecked="{Binding ShowCompletedPath}"
                        Foreground="{DynamicResource TextPrimaryBrush}"/>
              <CheckBox Grid.Row="2"
                        Grid.Column="1"
                        Content="Remaining"
                        IsChecked="{Binding ShowRemainingPath}"
                        Foreground="{DynamicResource TextPrimaryBrush}"/>
              <CheckBox Grid.Row="3"
                        Content="Stock Box"
                        IsChecked="{Binding ShowStockBox}"
                        Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Grid>

            <Border Height="1" Background="{DynamicResource BorderBrush}"/>

            <TextBlock Text="SCRUBBER"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="1"/>
            <TextBlock Text="{Binding ScrubberLabel}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <Slider Minimum="0"
                    Maximum="{Binding MainVm.ActiveGCodeDocument.TotalLines, TargetNullValue=1}"
                    Value="{Binding ScrubberValue, Mode=TwoWay}"/>
          </StackPanel>
        </Border>
        
      </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- Bottom Control Bar -->
    <Border Grid.Row="1"
            Background="{DynamicResource PanelBackgroundBrush}"
            CornerRadius="8"
            Padding="16"
            Margin="0,16,0,0">
      <Grid ColumnDefinitions="*,Auto">
        
        <!-- Main Control Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="12">
          <Button Classes="ControlButton Success"
                  Command="{Binding MainVm.StartCommand}"
                  IsEnabled="{Binding MainVm.CanStart}"
                  Padding="24,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="▶" FontSize="14"/>
              <TextBlock Text="START" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>
          
          <Button Classes="ControlButton Warning"
                  Command="{Binding MainVm.PauseCommand}"
                  IsEnabled="{Binding MainVm.CanPause}"
                  Padding="24,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="⏸" FontSize="14"/>
              <TextBlock Text="PAUSE" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>
          
          <Button Classes="ControlButton Danger"
                  Command="{Binding MainVm.StopCommand}"
                  IsEnabled="{Binding MainVm.CanStop}"
                  Padding="24,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="⏹" FontSize="14"/>
              <TextBlock Text="STOP" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>

          <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="8,0"/>

          <Button Classes="ControlButton"
                  Command="{Binding MainVm.HomeCommand}"
                  IsEnabled="{Binding MainVm.CanHome}"
                  Padding="24,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="H" FontSize="14"/>
              <TextBlock Text="HOME ALL" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- File Load Button -->
        <Button Grid.Column="1"
                Command="{Binding MainVm.GoFilesCommand}"
                Padding="16,12">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="F" FontSize="14"/>
            <TextBlock Text="Load File"/>
          </StackPanel>
        </Button>
        
      </Grid>
    </Border>
    
  </Grid>
</UserControl>
