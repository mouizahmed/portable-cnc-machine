<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             x:Class="PortableCncApp.Views.Pages.FilesView"
             x:DataType="vm:FilesViewModel"
             mc:Ignorable="d">

  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0" Classes="PanelCard Loose" Margin="0,0,0,8">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="FILE LIBRARY" Classes="PanelTitle"/>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
          <Button Content="Browse..."
                  Command="{Binding BrowseCommand}"
                  Classes="AppButton Primary"/>
          <Button Content="Refresh"
                  Command="{Binding RefreshCommand}"
                  Classes="AppButton"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="280,*">

      <Border Classes="PanelCard" Margin="0,0,12,0">
        <DockPanel LastChildFill="True">
          <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <StackPanel>
              <TextBlock Text="AVAILABLE FILES" Classes="PanelTitle"/>
              <TextBlock Text="{Binding Files.Count, StringFormat={}{0} file(s)}"
                         Classes="FieldLabel"
                         Margin="0,6,0,0"/>
            </StackPanel>
          </Grid>

          <Grid DockPanel.Dock="Bottom"
                ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="8"
                Margin="0,12,0,0">
            <Button Grid.Column="0"
                    Content="Load Selected"
                    Command="{Binding LoadSelectedCommand}"
                    IsEnabled="{Binding HasSelectedFile}"
                    Classes="AppButton Primary"/>
            <Button Grid.Column="2"
                    Content="Remove"
                    Command="{Binding RemoveCommand}"
                    IsEnabled="{Binding HasSelectedFile}"
                    Classes="AppButton"/>
          </Grid>

          <Border Classes="InsetSurface Subtle"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <ListBox ItemsSource="{Binding Files}"
                     SelectedItem="{Binding SelectedFile}"
                     Background="Transparent"
                     BorderThickness="0">
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="0"/>
                  <Setter Property="Margin" Value="0"/>
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="BorderThickness" Value="1"/>
                  <Setter Property="BorderBrush" Value="Transparent"/>
                  <Setter Property="CornerRadius" Value="6"/>
                  <Setter Property="Cursor" Value="Hand"/>
                </Style>
                <Style Selector="ListBoxItem:selected">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Style>
              </ListBox.Styles>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:GCodeFileInfo">
                  <Border Padding="10,8"
                          Margin="4,3"
                          Background="#272727"
                          CornerRadius="4">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Name}"
                                 Classes="SectionHeading"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <Border Grid.Column="1"
                              Background="#313131"
                              CornerRadius="4"
                              Padding="8,2"
                              Margin="10,0,0,0"
                              VerticalAlignment="Top">
                        <TextBlock Text="{Binding Size}" Classes="Caption" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </Border>

                      <TextBlock Grid.Row="1"
                                 Text="{Binding Modified, StringFormat=Modified {0}}"
                                 Classes="Caption"
                                 Margin="0,6,0,0"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
        </DockPanel>
      </Border>

      <Border Grid.Column="1" Classes="PanelCard">
        <Grid RowDefinitions="Auto,Auto,*">
          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <StackPanel>
              <TextBlock Text="PREVIEW WORKSPACE" Classes="PanelTitle"/>
              <TextBlock Text="{Binding SelectedFile.Name, TargetNullValue='No file selected'}"
                         Classes="CodeValue"
                         FontSize="15"
                         Margin="0,6,0,0"
                         TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Classes="InsetSurface"
                    VerticalAlignment="Top"
                    Padding="10,4">
              <TextBlock Text="{Binding PreviewLineCount, StringFormat={}{0} lines}"
                         Classes="FieldLabel"/>
            </Border>
          </Grid>

          <Grid Grid.Row="1"
                ColumnDefinitions="*,*"
                ColumnSpacing="8"
                Margin="0,0,0,10">
            <Border Background="#20262D"
                    CornerRadius="4"
                    Padding="10,8">
              <StackPanel>
                <TextBlock Text="Toolpath" Classes="Caption" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ToolpathStatusMessage}"
                           Classes="FieldValue"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#2A2420"
                    CornerRadius="4"
                    Padding="10,8">
              <StackPanel>
                <TextBlock Text="Warnings" Classes="Caption" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ToolpathWarningSummary, TargetNullValue='No parse warnings.'}"
                           Classes="FieldLabel"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="2" Classes="InsetSurface Code">
            <ScrollViewer>
              <TextBlock Text="{Binding FilePreview}"
                         Classes="CodeText"
                         TextWrapping="NoWrap"/>
            </ScrollViewer>
          </Border>
        </Grid>
      </Border>

    </Grid>
  </Grid>
</UserControl>
