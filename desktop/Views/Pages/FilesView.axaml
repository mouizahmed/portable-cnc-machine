<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             x:Class="PortableCncApp.Views.Pages.FilesView"
             x:DataType="vm:FilesViewModel"
             mc:Ignorable="d">

  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0"
            Background="{DynamicResource PanelBackgroundBrush}"
            CornerRadius="4"
            Padding="10"
            Margin="0,0,0,8">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="FILE LIBRARY"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     LetterSpacing="1"/>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
          <Button Content="Browse..."
                  Command="{Binding BrowseCommand}"
                  Padding="12,4"
                  FontSize="11"
                  Background="{DynamicResource AccentBrush}"/>
          <Button Content="Refresh"
                  Command="{Binding RefreshCommand}"
                  Padding="12,4"
                  FontSize="11"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="280,*">

      <Border Background="{DynamicResource PanelBackgroundBrush}"
              CornerRadius="4"
              Padding="8"
              Margin="0,0,12,0">
        <DockPanel LastChildFill="True">
          <Grid DockPanel.Dock="Top"
                Margin="0,0,0,10">
            <StackPanel>
              <TextBlock Text="AVAILABLE FILES"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         LetterSpacing="1"/>
              <TextBlock Text="{Binding Files.Count, StringFormat={}{0} file(s)}"
                         FontSize="11"
                         Margin="0,6,0,0"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
          </Grid>

          <Grid DockPanel.Dock="Bottom"
                ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="8"
                Margin="0,12,0,0">
            <Button Grid.Column="0"
                    Content="Load Selected"
                    Command="{Binding LoadSelectedCommand}"
                    IsEnabled="{Binding HasSelectedFile}"
                    Padding="12,4"
                    FontSize="11"
                    Background="{DynamicResource AccentBrush}"/>
            <Button Grid.Column="2"
                    Content="Remove"
                    Command="{Binding RemoveCommand}"
                    IsEnabled="{Binding HasSelectedFile}"
                    Padding="12,4"
                    FontSize="11"
                    Background="#3A3A3A"/>
          </Grid>

          <Border Background="#1F1F1F"
                  CornerRadius="4"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <ListBox ItemsSource="{Binding Files}"
                     SelectedItem="{Binding SelectedFile}"
                     Background="Transparent"
                     BorderThickness="0">
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="0"/>
                  <Setter Property="Margin" Value="0"/>
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="BorderThickness" Value="1"/>
                  <Setter Property="BorderBrush" Value="Transparent"/>
                  <Setter Property="CornerRadius" Value="6"/>
                  <Setter Property="Cursor" Value="Hand"/>
                </Style>
                <Style Selector="ListBoxItem:selected">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Style>
              </ListBox.Styles>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:GCodeFileInfo">
                  <Border Padding="10,8"
                          Margin="4,3"
                          Background="#272727"
                          CornerRadius="4">
                    <Grid RowDefinitions="Auto,Auto"
                          ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <Border Grid.Column="1"
                              Background="#313131"
                              CornerRadius="4"
                              Padding="8,2"
                              Margin="10,0,0,0"
                              VerticalAlignment="Top">
                        <TextBlock Text="{Binding Size}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </Border>

                      <TextBlock Grid.Row="1"
                                 Text="{Binding Modified, StringFormat=Modified {0}}"
                                 FontSize="10"
                                 Margin="0,6,0,0"
                                 Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
        </DockPanel>
      </Border>

      <Border Grid.Column="1"
              Background="{DynamicResource PanelBackgroundBrush}"
              CornerRadius="4"
              Padding="8">
        <Grid RowDefinitions="Auto,Auto,*">
          <Grid ColumnDefinitions="*,Auto"
                Margin="0,0,0,10">
            <StackPanel>
              <TextBlock Text="PREVIEW WORKSPACE"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         LetterSpacing="1"/>
              <TextBlock Text="{Binding SelectedFile.Name, TargetNullValue='No file selected'}"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Margin="0,6,0,0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#2A2A2A"
                    CornerRadius="4"
                    Padding="10,4"
                    VerticalAlignment="Top">
              <TextBlock Text="{Binding PreviewLineCount, StringFormat={}{0} lines}"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Border>
          </Grid>

          <Grid Grid.Row="1"
                ColumnDefinitions="*,*"
                ColumnSpacing="8"
                Margin="0,0,0,10">
            <Border Background="#20262D"
                    CornerRadius="4"
                    Padding="10,8">
              <StackPanel>
                <TextBlock Text="Toolpath"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           LetterSpacing="1"/>
                <TextBlock Text="{Binding ToolpathStatusMessage}"
                           FontSize="11"
                           Margin="0,6,0,0"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#2A2420"
                    CornerRadius="4"
                    Padding="10,8">
              <StackPanel>
                <TextBlock Text="Warnings"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           LetterSpacing="1"/>
                <TextBlock Text="{Binding ToolpathWarningSummary, TargetNullValue='No parse warnings.'}"
                           FontSize="11"
                           Margin="0,6,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="2"
                  Background="#171717"
                  CornerRadius="4"
                  Padding="10"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1">
            <ScrollViewer>
              <TextBlock Text="{Binding FilePreview}"
                         FontFamily="Consolas"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="NoWrap"/>
            </ScrollViewer>
          </Border>
        </Grid>
      </Border>

    </Grid>
  </Grid>
</UserControl>
