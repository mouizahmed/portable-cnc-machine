<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             xmlns:controls="clr-namespace:PortableCncApp.Controls"
             x:Class="PortableCncApp.Views.Pages.ConnectView"
             x:DataType="vm:ConnectViewModel"
             mc:Ignorable="d">

  <Grid RowDefinitions="Auto,*">
    <Grid Grid.Row="1" ColumnDefinitions="*,*">

      <controls:SectionCard Title="USB SERIAL CONNECTION" Margin="0,0,16,0">
        <controls:SectionCard.Body>
          <StackPanel Spacing="8">
            <StackPanel Spacing="12">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                  <TextBlock Text="Serial Port" Classes="SectionHeading"/>
                  <Button Grid.Column="1"
                          Content="Refresh"
                          Command="{Binding RefreshPortsCommand}"
                          Classes="AppButton"/>
                </Grid>
                <ComboBox ItemsSource="{Binding AvailablePorts}"
                          SelectedItem="{Binding SelectedPort}"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="Select COM port..."/>
              </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <Button Content="Connect"
                      Command="{Binding ConnectCommand}"
                      Classes="AppButton Primary"
                      IsEnabled="{Binding !IsConnecting}"/>
              <Button Content="Disconnect"
                      Command="{Binding DisconnectCommand}"
                      Classes="AppButton"/>
              <Button Content="Test"
                      Command="{Binding TestConnectionCommand}"
                      Classes="AppButton"
                      ToolTip.Tip="Send status query to verify connection"/>
            </StackPanel>

            <TextBlock Text="Connecting..."
                       Classes="SectionHeading"
                       Foreground="{DynamicResource WarningBrush}"
                       IsVisible="{Binding IsConnecting}"/>
          </StackPanel>
        </controls:SectionCard.Body>
      </controls:SectionCard>

      <controls:SectionCard Grid.Column="1" Title="DEVICE STATUS">
        <controls:SectionCard.Body>
          <StackPanel Spacing="8">
            <controls:SectionCard Title="Connection Status">
              <controls:SectionCard.Body>
                <controls:TwoColumnInfoGrid>
                  <StackPanel>
                    <TextBlock Text="Pico 2W" Classes="FieldValue"/>
                    <TextBlock Text="Safety Supervisor" Classes="FieldLabel Muted"/>
                  </StackPanel>
                  <controls:StatusPill Grid.Column="1"
                                       Text="{Binding MainVm.PiConnectionStatus}"
                                       PillBackground="{Binding MainVm.PiConnectionStatus, Converter={x:Static vm:ConnectionStatusToBrushConverter.Instance}}"/>

                  <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <TextBlock Text="Teensy 4.1" Classes="FieldValue"/>
                    <TextBlock Text="Motion Controller" Classes="FieldLabel Muted"/>
                  </StackPanel>
                  <controls:StatusPill Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="0,12,0,0"
                                       Text="{Binding MainVm.TeensyConnectionStatus}"
                                       PillBackground="{Binding MainVm.TeensyConnectionStatus, Converter={x:Static vm:ConnectionStatusToBrushConverter.Instance}}"/>
                </controls:TwoColumnInfoGrid>
              </controls:SectionCard.Body>
            </controls:SectionCard>

            <controls:SectionCard Title="Firmware Versions">
              <controls:SectionCard.Body>
                <controls:TwoColumnInfoGrid>
                  <TextBlock Text="Pico 2W Firmware" Classes="FieldValue" FontWeight="Normal"/>
                  <TextBlock Grid.Column="1" Text="{Binding PicoFirmware}" Classes="CodeText"/>

                  <TextBlock Grid.Row="1" Text="Teensy Firmware" Classes="FieldValue" FontWeight="Normal"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TeensyFirmware}" Classes="CodeText"/>

                  <TextBlock Grid.Row="2" Text="Pico Serial #" Classes="FieldValue" FontWeight="Normal"/>
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PicoSerialNumber}" Classes="CodeText"/>
                </controls:TwoColumnInfoGrid>
              </controls:SectionCard.Body>
            </controls:SectionCard>
          </StackPanel>
        </controls:SectionCard.Body>
      </controls:SectionCard>

    </Grid>
  </Grid>
</UserControl>
