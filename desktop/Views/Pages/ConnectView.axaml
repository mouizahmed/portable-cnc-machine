<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             x:Class="PortableCncApp.Views.Pages.ConnectView"
             x:DataType="vm:ConnectViewModel"
             mc:Ignorable="d">

  <Grid RowDefinitions="Auto,*">
    
    <!-- Page Header -->
    <StackPanel Margin="0,0,0,16">
      <TextBlock Text="Connection"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>
      <TextBlock Text="Connect to the Pico 2W controller via USB CDC Serial"
                 FontSize="13"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Main Content -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*">
      
      <!-- LEFT: Connection Settings -->
      <Border Background="{DynamicResource PanelBackgroundBrush}"
              CornerRadius="8"
              Padding="20"
              Margin="0,0,8,0">
        <StackPanel Spacing="20">
          
          <TextBlock Text="USB SERIAL CONNECTION"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     LetterSpacing="1"/>

          <!-- Serial Port Selection -->
          <StackPanel Spacing="12">
            <StackPanel>
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Text="Serial Port" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Button Grid.Column="1" Content="↻ Refresh" Command="{Binding RefreshPortsCommand}" Padding="10,4" FontSize="11"/>
              </Grid>
              <ComboBox ItemsSource="{Binding AvailablePorts}"
                        SelectedItem="{Binding SelectedPort}"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="Select COM port..."/>
            </StackPanel>

            <StackPanel>
              <TextBlock Text="Baud Rate" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
              <ComboBox ItemsSource="{Binding BaudRateOptions}"
                        SelectedItem="{Binding BaudRate}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
          </StackPanel>

          <!-- Connect/Disconnect Buttons -->
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
            <Button Content="Connect"
                    Command="{Binding ConnectCommand}"
                    Padding="24,12"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    IsEnabled="{Binding !IsConnecting}"/>
            <Button Content="Disconnect"
                    Command="{Binding DisconnectCommand}"
                    Padding="24,12"/>
            <Button Content="Test"
                    Command="{Binding TestConnectionCommand}"
                    Padding="16,12"
                    ToolTip.Tip="Send status query to verify connection"/>
          </StackPanel>

          <!-- Connecting Indicator -->
          <StackPanel Orientation="Horizontal" 
                      Spacing="8" 
                      IsVisible="{Binding IsConnecting}">
            <TextBlock Text="Connecting..." 
                       FontSize="12" 
                       Foreground="{DynamicResource WarningBrush}"/>
          </StackPanel>
          
        </StackPanel>
      </Border>

      <!-- RIGHT: Device Info -->
      <Border Grid.Column="1"
              Background="{DynamicResource PanelBackgroundBrush}"
              CornerRadius="8"
              Padding="20"
              Margin="8,0,0,0">
        <StackPanel Spacing="20">
          
          <TextBlock Text="DEVICE STATUS"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     LetterSpacing="1"/>

          <!-- Connection Status -->
          <Border Background="#2A2A2A" CornerRadius="6" Padding="16">
            <StackPanel Spacing="12">
              <TextBlock Text="Connection Status" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
              
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                <!-- Pico 2W Status -->
                <StackPanel>
                  <TextBlock Text="Pico 2W" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                  <TextBlock Text="Safety Supervisor" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
                <Border Grid.Column="1" 
                        Padding="10,4" 
                        CornerRadius="4"
                        Background="{Binding MainVm.PiConnectionStatus, Converter={x:Static vm:ConnectionStatusToBrushConverter.Instance}}">
                  <TextBlock Text="{Binding MainVm.PiConnectionStatus}" 
                             FontSize="11" 
                             FontWeight="SemiBold"
                             Foreground="White"/>
                </Border>
                
                <!-- Teensy Status -->
                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                  <TextBlock Text="Teensy 4.1" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                  <TextBlock Text="Motion Controller" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
                <Border Grid.Row="1" Grid.Column="1" 
                        Padding="10,4" 
                        CornerRadius="4"
                        Margin="0,12,0,0"
                        Background="{Binding MainVm.TeensyConnectionStatus, Converter={x:Static vm:ConnectionStatusToBrushConverter.Instance}}">
                  <TextBlock Text="{Binding MainVm.TeensyConnectionStatus}" 
                             FontSize="11" 
                             FontWeight="SemiBold"
                             Foreground="White"/>
                </Border>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Firmware Versions -->
          <Border Background="#2A2A2A" CornerRadius="6" Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="Firmware Versions" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
              
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Text="Pico 2W Firmware" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding PicoFirmware}" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas"/>
                
                <TextBlock Grid.Row="1" Text="Teensy Firmware" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TeensyFirmware}" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas" Margin="0,6,0,0"/>
                
                <TextBlock Grid.Row="2" Text="GRBL Version" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GrblVersion}" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas" Margin="0,6,0,0"/>

                <TextBlock Grid.Row="3" Text="Pico Serial #" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PicoSerialNumber}" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas" Margin="0,6,0,0"/>
              </Grid>
            </StackPanel>
          </Border>

        </StackPanel>
      </Border>
      
    </Grid>
  </Grid>
</UserControl>
