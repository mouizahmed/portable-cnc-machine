<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             xmlns:controls="clr-namespace:PortableCncApp.Controls"
             x:Class="PortableCncApp.Views.Pages.ManualControlView"
             x:DataType="vm:ManualControlViewModel"
             mc:Ignorable="d">

  <UserControl.Styles>
    <Style Selector="Button.JogPadButton">
      <Setter Property="Width" Value="46"/>
      <Setter Property="Height" Value="46"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Background" Value="#2A2A2A"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>
    <Style Selector="Button.JogPadButton:pointerover">
      <Setter Property="Background" Value="#313131"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
    </Style>
    <Style Selector="Button.JogPadButton:pressed">
      <Setter Property="Background" Value="#353535"/>
    </Style>
    <Style Selector="Border.JogPadGap">
      <Setter Property="Width" Value="46"/>
      <Setter Property="Height" Value="46"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Border.AxisBadge">
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="MinWidth" Value="32"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" RowDefinitions="*,*,Auto" RowSpacing="8">

    <controls:SectionCard Grid.Row="0" Grid.Column="0" Title="MOTION PAD" IsLoose="True">
      <controls:SectionCard.Body>
        <StackPanel Spacing="10">
          <Button Content="Cancel Jog"
                  Command="{Binding JogCancelCommand}"
                  IsEnabled="{Binding CanCancelJog}"
                  Classes="AppButton"
                  HorizontalAlignment="Center"/>

          <Grid ColumnDefinitions="Auto,Auto"
                ColumnSpacing="8"
                HorizontalAlignment="Center"
                IsEnabled="{Binding CanJogControls}">
            <StackPanel Spacing="4">
              <TextBlock Text="XY" Classes="Caption" FontWeight="SemiBold" HorizontalAlignment="Center"/>
              <Grid RowDefinitions="Auto,Auto,Auto"
                    ColumnDefinitions="Auto,Auto,Auto"
                    RowSpacing="4"
                    ColumnSpacing="4">
                <Button Grid.Row="0" Grid.Column="0" Classes="JogPadButton" Command="{Binding JogXMinusYPlusCommand}">
                  <materialIcons:MaterialIcon Kind="ArrowTopLeftBold" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
                <Button Grid.Row="0" Grid.Column="1" Classes="JogPadButton" Command="{Binding JogYPlusCommand}">
                  <materialIcons:MaterialIcon Kind="ArrowTopBold" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
                <Button Grid.Row="0" Grid.Column="2" Classes="JogPadButton" Command="{Binding JogXPlusYPlusCommand}">
                  <materialIcons:MaterialIcon Kind="ArrowTopRightBold" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
                <Button Grid.Row="1" Grid.Column="0" Classes="JogPadButton" Command="{Binding JogXMinusCommand}">
                  <materialIcons:MaterialIcon Kind="ArrowLeftBold" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
                <Border Grid.Row="1" Grid.Column="1" Classes="JogPadGap"/>
                <Button Grid.Row="1" Grid.Column="2" Classes="JogPadButton" Command="{Binding JogXPlusCommand}">
                  <materialIcons:MaterialIcon Kind="ArrowRightBold" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
                <Button Grid.Row="2" Grid.Column="0" Classes="JogPadButton" Command="{Binding JogXMinusYMinusCommand}">
                  <materialIcons:MaterialIcon Kind="ArrowBottomLeftBold" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
                <Button Grid.Row="2" Grid.Column="1" Classes="JogPadButton" Command="{Binding JogYMinusCommand}">
                  <materialIcons:MaterialIcon Kind="ArrowBottomBold" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
                <Button Grid.Row="2" Grid.Column="2" Classes="JogPadButton" Command="{Binding JogXPlusYMinusCommand}">
                  <materialIcons:MaterialIcon Kind="ArrowBottomRightBold" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
              </Grid>
            </StackPanel>

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4" VerticalAlignment="Top">
              <TextBlock Text="Z" Classes="Caption" FontWeight="SemiBold" HorizontalAlignment="Center"/>
              <Button Grid.Row="1" Classes="JogPadButton" Command="{Binding JogZPlusCommand}">
                <materialIcons:MaterialIcon Kind="ArrowTopBold" Width="16" Height="16" Foreground="{DynamicResource TextSecondaryBrush}"/>
              </Button>
              <Border Grid.Row="2" Classes="JogPadGap"/>
              <Button Grid.Row="3" Classes="JogPadButton" Command="{Binding JogZMinusCommand}">
                <materialIcons:MaterialIcon Kind="ArrowBottomBold" Width="16" Height="16" Foreground="{DynamicResource TextSecondaryBrush}"/>
              </Button>
            </Grid>
          </Grid>
        </StackPanel>
      </controls:SectionCard.Body>
    </controls:SectionCard>

    <controls:SectionCard Grid.Row="0" Grid.Column="1" Title="JOG SETTINGS">
      <controls:SectionCard.Body>
        <StackPanel Spacing="8">
          <StackPanel Spacing="4">
            <TextBlock Text="Step Size" Classes="FieldLabel"/>
            <WrapPanel ItemSpacing="4" LineSpacing="4">
              <Button Content="0.01" Command="{Binding SetStepCommand}" CommandParameter="0.01" Classes="StepButton"/>
              <Button Content="0.1" Command="{Binding SetStepCommand}" CommandParameter="0.1" Classes="StepButton"/>
              <Button Content="1" Command="{Binding SetStepCommand}" CommandParameter="1" Classes="StepButton"/>
              <Button Content="10" Command="{Binding SetStepCommand}" CommandParameter="10" Classes="StepButton"/>
              <Button Content="50" Command="{Binding SetStepCommand}" CommandParameter="50" Classes="StepButton"/>
            </WrapPanel>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Jog Feed" Classes="FieldLabel"/>
            <NumericUpDown Value="{Binding JogFeedRate}"
                           Minimum="1"
                           Maximum="5000"
                           Increment="100"
                           FormatString="F0"/>
          </StackPanel>

          <CheckBox Content="Continuous Jog"
                    IsChecked="{Binding ContinuousJog}"
                    Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
      </controls:SectionCard.Body>
    </controls:SectionCard>

    <controls:SectionCard Grid.Row="0" Grid.Column="2" Title="SPINDLE">
      <controls:SectionCard.Body>
        <StackPanel Spacing="8">
          <StackPanel Spacing="4">
            <TextBlock Text="Spindle Target" Classes="FieldLabel"/>
            <NumericUpDown Value="{Binding SpindleTargetRpm}"
                           Minimum="{Binding SpindleMinRpm}"
                           Maximum="{Binding SpindleMaxRpm}"
                           Increment="500"
                           FormatString="F0"
                           IsEnabled="{Binding CanUseAuxControls}"/>
          </StackPanel>

          <WrapPanel ItemSpacing="4" LineSpacing="4">
            <Button Content="Spindle Start" Command="{Binding StartSpindleCommand}" Classes="AppButton Primary" IsEnabled="{Binding CanUseAuxControls}"/>
            <Button Content="Spindle Stop" Command="{Binding StopSpindleCommand}" Classes="AppButton" IsEnabled="{Binding CanUseAuxControls}"/>
          </WrapPanel>
        </StackPanel>
      </controls:SectionCard.Body>
    </controls:SectionCard>

    <controls:SectionCard Grid.Row="1" Grid.Column="0" Title="OVERRIDES">
      <controls:SectionCard.Body>
        <StackPanel Spacing="8">
          <StackPanel Spacing="4">
            <controls:TwoColumnInfoGrid>
              <TextBlock Text="Feed" Classes="FieldLabel" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1" Text="{Binding FeedOverride, StringFormat={}{0}%}" Classes="FieldValue"/>
            </controls:TwoColumnInfoGrid>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
              <Button Content="-10" Command="{Binding FeedOverrideMinusCommand}" Classes="AppButton" HorizontalAlignment="Stretch" IsEnabled="{Binding CanUseOverrides}"/>
              <Button Grid.Column="1" Content="100%" Command="{Binding FeedOverrideResetCommand}" Classes="AppButton" HorizontalAlignment="Stretch" IsEnabled="{Binding CanUseOverrides}"/>
              <Button Grid.Column="2" Content="+10" Command="{Binding FeedOverridePlusCommand}" Classes="AppButton" HorizontalAlignment="Stretch" IsEnabled="{Binding CanUseOverrides}"/>
            </Grid>
          </StackPanel>

          <StackPanel Spacing="4">
            <controls:TwoColumnInfoGrid>
              <TextBlock Text="Spindle" Classes="FieldLabel" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1" Text="{Binding SpindleOverride, StringFormat={}{0}%}" Classes="FieldValue"/>
            </controls:TwoColumnInfoGrid>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
              <Button Content="-10" Command="{Binding SpindleOverrideMinusCommand}" Classes="AppButton" HorizontalAlignment="Stretch" IsEnabled="{Binding CanUseOverrides}"/>
              <Button Grid.Column="1" Content="100%" Command="{Binding SpindleOverrideResetCommand}" Classes="AppButton" HorizontalAlignment="Stretch" IsEnabled="{Binding CanUseOverrides}"/>
              <Button Grid.Column="2" Content="+10" Command="{Binding SpindleOverridePlusCommand}" Classes="AppButton" HorizontalAlignment="Stretch" IsEnabled="{Binding CanUseOverrides}"/>
            </Grid>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Rapid" Classes="FieldLabel"/>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
              <Button Content="25%" Command="{Binding RapidOverride25Command}" Classes="AppButton" HorizontalAlignment="Stretch" IsEnabled="{Binding CanUseOverrides}"/>
              <Button Grid.Column="1" Content="50%" Command="{Binding RapidOverride50Command}" Classes="AppButton" HorizontalAlignment="Stretch" IsEnabled="{Binding CanUseOverrides}"/>
              <Button Grid.Column="2" Content="100%" Command="{Binding RapidOverride100Command}" Classes="AppButton" HorizontalAlignment="Stretch" IsEnabled="{Binding CanUseOverrides}"/>
            </Grid>
          </StackPanel>
        </StackPanel>
      </controls:SectionCard.Body>
    </controls:SectionCard>

    <controls:SectionCard Grid.Row="1" Grid.Column="1" Title="HOMING AND ZERO">
      <controls:SectionCard.Body>
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <TextBlock Text="Homed" Classes="FieldLabel" VerticalAlignment="Center"/>
            <WrapPanel Grid.Column="1" ItemSpacing="4" LineSpacing="4">
              <Border Classes="AxisBadge" Background="{Binding XHomed, Converter={x:Static vm:BoolToStatusBrushConverter.Instance}}">
                <TextBlock Text="X" Classes="Caption" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
              </Border>
              <Border Classes="AxisBadge" Background="{Binding YHomed, Converter={x:Static vm:BoolToStatusBrushConverter.Instance}}">
                <TextBlock Text="Y" Classes="Caption" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
              </Border>
              <Border Classes="AxisBadge" Background="{Binding ZHomed, Converter={x:Static vm:BoolToStatusBrushConverter.Instance}}">
                <TextBlock Text="Z" Classes="Caption" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
              </Border>
            </WrapPanel>
          </Grid>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <StackPanel Spacing="4">
              <TextBlock Text="HOME" Classes="FieldLabel" FontWeight="SemiBold"/>
              <WrapPanel ItemSpacing="4" LineSpacing="4" IsEnabled="{Binding CanHomeControls}">
                <Button Content="All" Command="{Binding HomeAllCommand}" Classes="AppButton Primary"/>
                <Button Content="X" Command="{Binding HomeXCommand}" Classes="AppButton"/>
                <Button Content="Y" Command="{Binding HomeYCommand}" Classes="AppButton"/>
                <Button Content="Z" Command="{Binding HomeZCommand}" Classes="AppButton"/>
              </WrapPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="WORK ZERO" Classes="FieldLabel" FontWeight="SemiBold"/>
              <WrapPanel ItemSpacing="4" LineSpacing="4" IsEnabled="{Binding IsMachineConnected}">
                <Button Content="All" Command="{Binding ZeroAllCommand}" Classes="AppButton Primary"/>
                <Button Content="X=0" Command="{Binding ZeroXCommand}" Classes="AppButton"/>
                <Button Content="Y=0" Command="{Binding ZeroYCommand}" Classes="AppButton"/>
                <Button Content="Z=0" Command="{Binding ZeroZCommand}" Classes="AppButton"/>
              </WrapPanel>
            </StackPanel>
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderBrush}"/>

          <StackPanel Spacing="4">
            <TextBlock Text="RECOVERY" Classes="FieldLabel" FontWeight="SemiBold"/>
            <WrapPanel ItemSpacing="4" LineSpacing="4">
              <Button Content="Unlock Alarm" Command="{Binding AlarmUnlockCommand}" IsEnabled="{Binding CanAlarmUnlock}" Classes="AppButton Danger"/>
              <Button Content="Soft Reset" Command="{Binding SoftResetCommand}" IsEnabled="{Binding CanSoftReset}" Classes="AppButton"/>
            </WrapPanel>
          </StackPanel>
        </StackPanel>
      </controls:SectionCard.Body>
    </controls:SectionCard>

    <controls:SectionCard Grid.Row="1" Grid.Column="2" Title="PROBE">
      <controls:SectionCard.Body>
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <StackPanel Spacing="4">
              <TextBlock Text="Depth (mm)" Classes="FieldLabel"/>
              <NumericUpDown Value="{Binding ProbeDepth}" Minimum="0.1" Maximum="100" Increment="1" FormatString="F1" IsEnabled="{Binding CanProbe}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="Feed (mm/min)" Classes="FieldLabel"/>
              <NumericUpDown Value="{Binding ProbeFeed}" Minimum="1" Maximum="500" Increment="10" FormatString="F0" IsEnabled="{Binding CanProbe}"/>
            </StackPanel>
          </Grid>

          <Button Content="Probe Z" Command="{Binding ProbeZCommand}" IsEnabled="{Binding CanProbe}" Classes="AppButton Primary"/>

          <TextBlock Text="Jog Z near stock, probe down, then set Z=0." Classes="FieldLabel" TextWrapping="Wrap"/>
        </StackPanel>
      </controls:SectionCard.Body>
    </controls:SectionCard>

    <controls:SectionCard Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Title="CUSTOM COMMAND">
      <controls:SectionCard.Body>
        <StackPanel Spacing="6">
          <TextBlock Text="Send any GRBL command directly ($X, G0, $$, etc.)" Classes="FieldLabel"/>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
            <TextBox Text="{Binding CustomCommand}"
                     FontFamily="Consolas"
                     AcceptsReturn="False"
                     Watermark="e.g. $$ or G0 X0 Y0">
              <TextBox.KeyBindings>
                <KeyBinding Gesture="Enter" Command="{Binding SendCustomCommandCommand}"/>
              </TextBox.KeyBindings>
            </TextBox>
            <Button Grid.Column="1"
                    Content="Send"
                    Command="{Binding SendCustomCommandCommand}"
                    IsEnabled="{Binding CanSendCustomCommand}"
                    Classes="AppButton"/>
          </Grid>
        </StackPanel>
      </controls:SectionCard.Body>
    </controls:SectionCard>

  </Grid>
</UserControl>
