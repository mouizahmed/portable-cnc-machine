<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
             xmlns:controls="clr-namespace:PortableCncApp.Controls"
             x:Class="PortableCncApp.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel"
             mc:Ignorable="d">

  <Grid>
    <controls:SectionCard Title="SETTINGS"
                          Subtitle="Work in progress.">
      <controls:SectionCard.Body>
        <Border Classes="InsetSurface Subtle"
                Padding="16"
                Height="NaN"
                MinHeight="0">
          <StackPanel Spacing="6">
            <TextBlock Text="WORK IN PROGRESS"
                       Classes="FieldValue"
                       FontSize="16"/>
            <TextBlock Text="Settings controls have been temporarily removed while this page is being redesigned."
                       Classes="FieldLabel"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
      </controls:SectionCard.Body>
    </controls:SectionCard>
  </Grid>
</UserControl>
