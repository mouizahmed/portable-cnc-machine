<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
        xmlns:controls="clr-namespace:PortableCncApp.Controls"
        xmlns:converters="clr-namespace:PortableCncApp.ViewModels"
        x:Class="PortableCncApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d"
        Width="1024"
        Height="700"
        MinWidth="1024"
        MinHeight="700"
        CanResize="False"
        Title="Portable CNC Control"
        Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,248">

    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="{DynamicResource SidebarBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="2" Margin="8,0">
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Dashboard}"
                Command="{Binding GoDashboardCommand}">
          <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=ManualControl}"
                Command="{Binding GoManualControlCommand}">
          <TextBlock Text="Manual Control" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Files}"
                Command="{Binding GoFilesCommand}">
          <TextBlock Text="Files" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Connect}"
                Command="{Binding GoConnectCommand}">
          <TextBlock Text="Connect" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Settings}"
                Command="{Binding GoSettingsCommand}">
          <TextBlock Text="Settings" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Diagnostics}"
                Command="{Binding GoDiagnosticsCommand}">
          <TextBlock Text="Diagnostics" VerticalAlignment="Center"/>
        </Button>
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Margin="8">
      <ContentControl Content="{Binding CurrentPage}"/>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="1"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1,0,0,0">
      <Grid RowDefinitions="Auto,1,*">

        <StackPanel Grid.Row="0" Spacing="8" Margin="8">
          <controls:SectionCard Title="COORDINATES">
            <controls:SectionCard.Body>
              <StackPanel Spacing="8">
                <controls:ReadoutRow Label="Work" Value="{Binding WorkCoordinatesText}"/>
                <controls:ReadoutRow Label="Machine" Value="{Binding MachineCoordinatesText}" IsMuted="True"/>
              </StackPanel>
            </controls:SectionCard.Body>
          </controls:SectionCard>

          <controls:SectionCard Title="MACHINE">
            <controls:SectionCard.Body>
              <StackPanel Spacing="8">
                <controls:StatusPill Text="{Binding MotionStateLabel}"
                                     PillBackground="{Binding MotionStateBrush}"/>

                <controls:TwoColumnInfoGrid>
                  <TextBlock Text="Connection" Classes="FieldLabel"/>
                  <TextBlock Grid.Column="1" Text="{Binding ConnectionStatusText}" Classes="FieldValue"/>

                  <TextBlock Grid.Row="1" Text="Safety" Classes="FieldLabel"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SafetyStateLabel}" Classes="FieldValue"/>

                  <TextBlock Grid.Row="2" Text="Feed / Spindle" Classes="FieldLabel"/>
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FeedSpindleSummary}" Classes="FieldValue"/>
                </controls:TwoColumnInfoGrid>
              </StackPanel>
            </controls:SectionCard.Body>
          </controls:SectionCard>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource BorderBrush}"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="8">
          <ContentControl Content="{Binding CurrentPage}">
            <ContentControl.DataTemplates>
              <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <controls:SectionCard Title="DASHBOARD">
                  <controls:SectionCard.Body>
                    <StackPanel>
                      <TextBlock Text="{Binding MainVm.CurrentFileName, TargetNullValue='No file loaded'}"
                                 Classes="CodeValue"
                                 TextTrimming="CharacterEllipsis"/>

                      <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,4">
                        <TextBlock Text="Progress" Classes="FieldLabel"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding MainVm.Progress, StringFormat={}{0:F1}%}"
                                   Classes="FieldLabel"/>
                      </Grid>

                      <ProgressBar Value="{Binding MainVm.Progress}" Maximum="100" Height="8" CornerRadius="4"/>

                      <TextBlock Text="{Binding MainVm.CurrentLine, StringFormat=Line {0}}"
                                 Classes="FieldLabel Muted"
                                 Margin="0,8,0,0"/>
                      <TextBlock Text="{Binding MainVm.ActiveToolpathBounds}" Classes="FieldLabel" Margin="0,6,0,0"/>
                      <TextBlock Text="{Binding MainVm.ActiveToolpathDepth}" Classes="FieldLabel" Margin="0,4,0,0"/>
                    </StackPanel>
                  </controls:SectionCard.Body>
                </controls:SectionCard>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:FilesViewModel}">
                <StackPanel Spacing="8">
                  <controls:SectionCard Title="SELECTION">
                    <controls:SectionCard.Body>
                      <StackPanel Spacing="8">
                        <controls:StatusPill Text="{Binding ToolpathStateLabel}"
                                             PillBackground="{Binding ToolpathStateBrush}"/>
                        <TextBlock Text="{Binding FilePreviewTitle}"
                                   Classes="CodeValue"
                                   IsVisible="{Binding HasSelectedFile}"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Spacing="8"
                                    IsVisible="{Binding HasSelectedFile}">
                          <TextBlock Text="{Binding SelectedFilePathSummary}"
                                     Classes="FieldLabel"
                                     TextWrapping="Wrap"/>

                          <controls:TwoColumnInfoGrid>
                            <TextBlock Text="Size" Classes="FieldLabel"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedFile.Size, TargetNullValue='--'}"
                                       Classes="FieldValue"/>

                            <TextBlock Grid.Row="1" Text="Modified" Classes="FieldLabel"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding SelectedFile.Modified, TargetNullValue='--'}"
                                       Classes="FieldValue"/>

                            <TextBlock Grid.Row="2" Text="Lines" Classes="FieldLabel"/>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding SelectedFileLineSummary}"
                                       Classes="FieldValue"/>
                          </controls:TwoColumnInfoGrid>

                          <Button Content="Load Into Dashboard"
                                  Command="{Binding LoadSelectedCommand}"
                                  IsEnabled="{Binding HasSelectedFile}"
                                  HorizontalAlignment="Stretch"
                                  Classes="AppButton Primary"/>
                          <Button Content="Remove From Library"
                                  Command="{Binding RemoveCommand}"
                                  IsEnabled="{Binding HasSelectedFile}"
                                  HorizontalAlignment="Stretch"
                                  Classes="AppButton"/>
                        </StackPanel>
                      </StackPanel>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>

                </StackPanel>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:ManualControlViewModel}">
                <controls:SectionCard Title="MANUAL CONTROL">
                  <controls:SectionCard.Body>
                    <StackPanel Spacing="8">
                      <controls:TwoColumnInfoGrid>
                        <TextBlock Text="Step" Classes="FieldLabel"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding JogStep, StringFormat={}{0} mm}"
                                   Classes="FieldValue"/>

                        <TextBlock Grid.Row="1" Text="Feed" Classes="FieldLabel"/>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding JogFeedRate, StringFormat={}{0:F0} mm/min}"
                                   Classes="FieldValue"/>

                        <TextBlock Grid.Row="2" Text="Mode" Classes="FieldLabel"/>
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding JogModeText}"
                                   Classes="FieldValue"/>

                        <TextBlock Grid.Row="3" Text="Home" Classes="FieldLabel"/>
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding HomingStatusText}"
                                   Classes="FieldValue"/>

                        <TextBlock Grid.Row="4" Text="Overrides" Classes="FieldLabel"/>
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Text="{Binding FeedOverride, StringFormat=F {0}%}"
                                   Classes="FieldValue"/>
                        <TextBlock Grid.Row="5"
                                   Grid.Column="1"
                                   Text="{Binding SpindleOverride, StringFormat=S {0}%}"
                                   Classes="FieldValue"/>
                        <TextBlock Grid.Row="6"
                                   Grid.Column="1"
                                   Text="{Binding RapidOverride, StringFormat=R {0}%}"
                                   Classes="FieldValue"/>

                        <TextBlock Grid.Row="7" Text="Spindle" Classes="FieldLabel"/>
                        <TextBlock Grid.Row="7"
                                   Grid.Column="1"
                                   Text="{Binding SpindleStatusText}"
                                   Classes="FieldValue"/>
                      </controls:TwoColumnInfoGrid>

                      <TextBlock Text="{Binding CommandPreview}"
                                 Classes="CodeText"
                                 FontSize="10"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </controls:SectionCard.Body>
                </controls:SectionCard>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:ConnectViewModel}">
                <controls:SectionCard Title="DEVICE">
                  <controls:SectionCard.Body>
                    <controls:TwoColumnInfoGrid>
                      <TextBlock Text="Port" Classes="FieldLabel"/>
                      <TextBlock Grid.Column="1" Text="{Binding SelectedPort, TargetNullValue='--'}" Classes="FieldValue"/>

                      <TextBlock Grid.Row="1" Text="Pico FW" Classes="FieldLabel"/>
                      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PicoFirmware}" Classes="FieldValue"/>

                      <TextBlock Grid.Row="2" Text="Teensy FW" Classes="FieldLabel"/>
                      <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TeensyFirmware}" Classes="FieldValue"/>

                      <TextBlock Grid.Row="3" Text="Serial" Classes="FieldLabel"/>
                      <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PicoSerialNumber}" Classes="FieldValue"/>
                    </controls:TwoColumnInfoGrid>
                  </controls:SectionCard.Body>
                </controls:SectionCard>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <controls:SectionCard Title="SETTINGS">
                  <controls:SectionCard.Body>
                    <controls:TwoColumnInfoGrid>
                      <TextBlock Text="Units" Classes="FieldLabel"/>
                      <TextBlock Grid.Column="1" Text="{Binding Units}" Classes="FieldValue"/>

                      <TextBlock Grid.Row="1" Text="Soft limits" Classes="FieldLabel"/>
                      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SoftLimitsEnabled}" Classes="FieldValue"/>

                      <TextBlock Grid.Row="2" Text="Hard limits" Classes="FieldLabel"/>
                      <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HardLimitsEnabled}" Classes="FieldValue"/>

                      <TextBlock Grid.Row="3" Text="Spindle max" Classes="FieldLabel"/>
                      <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SpindleMaxRpm, StringFormat={}{0:F0} RPM}" Classes="FieldValue"/>
                    </controls:TwoColumnInfoGrid>
                  </controls:SectionCard.Body>
                </controls:SectionCard>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:DiagnosticsViewModel}">
                <StackPanel Spacing="8">
                  <controls:SectionCard Title="DIAGNOSTICS">
                    <controls:SectionCard.Body>
                      <StackPanel>
                        <TextBlock Text="{Binding MainVm.StatusMessage}" Classes="FieldValue" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding MainVm.IsStatusError, StringFormat=Active fault: {0}}" Classes="FieldLabel" Margin="0,6,0,0"/>
                      </StackPanel>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>

                  <controls:SectionCard Title="CONSOLE">
                    <controls:SectionCard.Body>
                      <StackPanel>
                        <TextBlock Text="{Binding LogEntryCount, StringFormat={}{0} entries}" Classes="FieldLabel"/>
                        <TextBlock Text="{Binding LatestLogSummary}" Classes="FieldValue" TextWrapping="Wrap" Margin="0,6,0,0"/>
                      </StackPanel>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>
                </StackPanel>
              </DataTemplate>
            </ContentControl.DataTemplates>
          </ContentControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="{DynamicResource HeaderBackgroundBrush}"
            Padding="8"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">

        <StackPanel Orientation="Horizontal" Spacing="4">
          <Button Classes="AppButton Success"
                  Command="{Binding StartCommand}"
                  IsEnabled="{Binding CanStart}"
                  Content="START"/>
          <Button Classes="AppButton Warning"
                  Command="{Binding PauseCommand}"
                  IsEnabled="{Binding CanPause}"
                  Content="PAUSE"/>
          <Button Classes="AppButton Danger"
                  Command="{Binding StopCommand}"
                  IsEnabled="{Binding CanStop}"
                  Content="STOP"/>

          <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,0"/>

          <Button Classes="AppButton"
                  Command="{Binding HomeCommand}"
                  IsEnabled="{Binding CanHome}"
                  Content="HOME ALL"/>

          <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,0"/>

          <Button Classes="AppButton"
                  Command="{Binding GoFilesCommand}"
                  Content="Load File"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0">
          <TextBlock Text="Status:" Classes="FieldLabel" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding StatusMessage}" Classes="FieldValue" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="8,0" IsVisible="{Binding IsConnected}">
          <TextBlock Text="Feed:" Classes="FieldLabel" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding FeedRate, StringFormat={}{0:F0}}" Classes="FieldValue" FontWeight="Normal" VerticalAlignment="Center"/>
          <TextBlock Text="mm/min" Classes="FieldLabel" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="8,0" IsVisible="{Binding IsConnected}">
          <TextBlock Text="Temp:" Classes="FieldLabel" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding Temperature, StringFormat={}{0:F1} deg C}" Classes="FieldValue" FontWeight="Normal" VerticalAlignment="Center"/>
        </StackPanel>

        <controls:StatusPill Grid.Column="4"
                             IsVisible="{Binding IsConnected}"
                             Margin="8,0,0,0"
                             Prefix="MOTION:"
                             Text="{Binding MotionStateLabel}"
                             PillBackground="{Binding MotionStateBrush}"
                             LabelForeground="#CCFFFFFF"/>

        <Button Grid.Column="5"
                Classes="AppButton Danger"
                IsEnabled="{Binding IsConnected}"
                FontWeight="Bold"
                Command="{Binding EStopCommand}"
                Content="E-STOP"/>
      </Grid>
    </Border>

  </Grid>
</Window>
