<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialIcons="using:Material.Icons.Avalonia"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
        xmlns:converters="clr-namespace:PortableCncApp.ViewModels"
        x:Class="PortableCncApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d"
        Width="1280"
        Height="800"
        MinWidth="1024"
        MinHeight="700"
        Title="Portable CNC Control"
        Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- TAB NAVIGATION BAR -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="{DynamicResource SidebarBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">

        <!-- Tab Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="2" Margin="4,0">

          <Button Classes="NavButton"
                  Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Dashboard}"
                  Command="{Binding GoDashboardCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <materialIcons:MaterialIcon Kind="Play" />
              <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="NavButton"
                  Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Jog}"
                  Command="{Binding GoJogCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <materialIcons:MaterialIcon Kind="CameraControl" />
              <TextBlock Text="Jog Control" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="NavButton"
                  Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Files}"
                  Command="{Binding GoFilesCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <materialIcons:MaterialIcon Kind="Folder" />
              <TextBlock Text="Files" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="NavButton"
                  Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Connect}"
                  Command="{Binding GoConnectCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <materialIcons:MaterialIcon Kind="PowerPlug" />
              <TextBlock Text="Connect" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="NavButton"
                  Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Settings}"
                  Command="{Binding GoSettingsCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <materialIcons:MaterialIcon Kind="Settings" />
              <TextBlock Text="Settings" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="NavButton"
                  Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Diagnostics}"
                  Command="{Binding GoDiagnosticsCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <materialIcons:MaterialIcon Kind="Wrench" />
              <TextBlock Text="Diagnostics" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

        </StackPanel>

        <!-- Right: Connection Status + E-STOP -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0" VerticalAlignment="Center">

          <!-- Connection Status -->
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Ellipse Width="8" Height="8" Fill="{Binding ConnectionStatusBrush}"/>
            <TextBlock Text="{Binding ConnectionStatusText}"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Motion State Pill -->
          <Border IsVisible="{Binding IsConnected}"
                  Padding="10,4"
                  CornerRadius="4"
                  Background="{Binding MotionStateBrush}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="MOTION:"
                         FontSize="10"
                         Foreground="#CCFFFFFF"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding MotionStateLabel}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="White"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- E-STOP -->
          <Button IsVisible="{Binding IsConnected}"
                  Padding="16,6"
                  Background="{DynamicResource DangerBrush}"
                  Foreground="White"
                  FontWeight="Bold"
                  FontSize="13"
                  CornerRadius="4"
                  Command="{Binding EStopCommand}">
            E-STOP
          </Button>

        </StackPanel>

      </Grid>
    </Border>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- PAGE CONTENT -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="1" Padding="20">
      <ContentControl Content="{Binding CurrentPage}"/>
    </Border>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- STATUS BAR -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="2"
            Background="{DynamicResource HeaderBackgroundBrush}"
            Padding="16,8"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">

        <!-- Status Message -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Status:"
                     FontSize="12"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <TextBlock Text="{Binding StatusMessage}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- Feed Rate -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="20,0"
                    IsVisible="{Binding IsConnected}">
          <TextBlock Text="Feed:"
                     FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <TextBlock Text="{Binding FeedRate, StringFormat={}{0:F0}}"
                     FontSize="11"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock Text="mm/min"
                     FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Temperature -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="20,0"
                    IsVisible="{Binding IsConnected}">
          <TextBlock Text="Temp:"
                     FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <TextBlock Text="{Binding Temperature, StringFormat={}{0:F1}°C}"
                     FontSize="11"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- Current Page Indicator -->
        <TextBlock Grid.Column="3"
                   Text="{Binding CurrentPageName}"
                   FontSize="11"
                   Foreground="{DynamicResource TextTertiaryBrush}"/>

      </Grid>
    </Border>

  </Grid>
</Window>
