<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PortableCncApp.ViewModels"
        xmlns:controls="clr-namespace:PortableCncApp.Controls"
        xmlns:converters="clr-namespace:PortableCncApp.ViewModels"
        x:Class="PortableCncApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d"
        Width="1080"
        Height="800"
        MinWidth="1080"
        MinHeight="800"
        CanResize="False"
        Title="Portable CNC Control"
        Icon="/Assets/app-icon.png"
        Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,248">

    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="{DynamicResource SidebarBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="2" Margin="8,0">
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Dashboard}"
                Command="{Binding GoDashboardCommand}">
          <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=ManualControl}"
                Command="{Binding GoManualControlCommand}">
          <TextBlock Text="Manual Control" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Files}"
                Command="{Binding GoFilesCommand}">
          <TextBlock Text="Files" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Connect}"
                Command="{Binding GoConnectCommand}">
          <TextBlock Text="Connect" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Settings}"
                Command="{Binding GoSettingsCommand}">
          <TextBlock Text="Settings" VerticalAlignment="Center"/>
        </Button>
        <Button Classes="NavButton"
                Classes.active="{Binding CurrentPageName, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Diagnostics}"
                Command="{Binding GoDiagnosticsCommand}">
          <TextBlock Text="Diagnostics" VerticalAlignment="Center"/>
        </Button>
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Margin="8">
      <ContentControl Content="{Binding CurrentPage}"
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Stretch"/>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="1"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1,0,0,0">
      <Grid RowDefinitions="Auto,1,*">

        <StackPanel Grid.Row="0" Spacing="8" Margin="8">
          <controls:SectionCard Title="COORDINATES">
            <controls:SectionCard.Body>
              <StackPanel Spacing="8">
                <controls:ReadoutRow Label="W" Value="{Binding WorkCoordinatesText}"/>
                <controls:ReadoutRow Label="M" Value="{Binding MachineCoordinatesText}" IsMuted="True"/>
              </StackPanel>
            </controls:SectionCard.Body>
          </controls:SectionCard>

          <controls:SectionCard Title="MACHINE">
            <controls:SectionCard.Body>
              <StackPanel Spacing="8">
                <controls:StatusPill Text="{Binding MotionStateLabel}"
                                     PillBackground="{Binding MotionStateBrush}"/>

                <controls:TwoColumnInfoGrid>
                  <TextBlock Text="Connection" Classes="FieldLabel"/>
                  <TextBlock Grid.Column="1" Text="{Binding ConnectionStatusText}" Classes="FieldValue"/>

                  <TextBlock Grid.Row="1" Text="Safety" Classes="FieldLabel"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SafetyStateLabel}" Classes="FieldValue"/>

                  <TextBlock Grid.Row="2" Text="Feed / Spindle" Classes="FieldLabel"/>
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FeedSpindleSummary}" Classes="FieldValue"/>
                </controls:TwoColumnInfoGrid>
              </StackPanel>
            </controls:SectionCard.Body>
          </controls:SectionCard>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource BorderBrush}"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="8">
          <ContentControl Content="{Binding CurrentPage}">
            <ContentControl.DataTemplates>
              <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <StackPanel Spacing="8">
                  <controls:SectionCard Title="SELECTED PREVIEW"
                                        IsVisible="{Binding MainVm.FilesVm.ShowSelectedPreviewCard}">
                    <controls:SectionCard.Body>
                      <controls:FileStateCard Header="{Binding MainVm.FilesVm.SelectedPreviewHeaderText}"
                                              FileName="{Binding MainVm.FilesVm.SelectedPreviewFileName}"
                                              SizeText="{Binding MainVm.FilesVm.SelectedPreviewSizeText}"
                                              LinesText="{Binding MainVm.FilesVm.SelectedPreviewLinesText}"
                                              StatusText="{Binding MainVm.FilesVm.SelectedPreviewStatusText}"
                                              StatusBackground="{Binding MainVm.FilesVm.SelectedPreviewStatusBrush}"
                                              PrimaryActionText="{Binding MainVm.FilesVm.SelectedPreviewPrimaryActionText}"
                                              PrimaryActionCommand="{Binding MainVm.FilesVm.SelectedPreviewPrimaryActionCommand}"
                                              EmphasizePrimaryAction="True"/>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>

                  <controls:SectionCard Title="LOADED JOB"
                                        IsVisible="{Binding MainVm.FilesVm.ShowLoadedJobCard}">
                    <controls:SectionCard.Body>
                      <StackPanel Spacing="6">
                        <controls:StatusPill Text="{Binding MainVm.FilesVm.LoadedJobFileName}"
                                             PillBackground="{Binding MainVm.FilesVm.LoadedJobStatusBrush}"/>

                        <controls:TwoColumnInfoGrid>
                          <TextBlock Text="Size" Classes="FieldLabel"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding MainVm.FilesVm.LoadedJobSizeText}"
                                     Classes="FieldValue"/>

                          <TextBlock Grid.Row="1" Text="Lines" Classes="FieldLabel"/>
                          <TextBlock Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding MainVm.FilesVm.LoadedJobLinesText}"
                                     Classes="FieldValue"/>
                        </controls:TwoColumnInfoGrid>

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                          <TextBlock Text="Progress" Classes="FieldLabel"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding MainVm.Progress, StringFormat={}{0:F1}%}"
                                     Classes="FieldLabel"/>
                        </Grid>

                        <ProgressBar Value="{Binding MainVm.Progress}" Maximum="100" Height="8" CornerRadius="4"/>

                        <TextBlock Text="{Binding MainVm.CurrentLine, StringFormat=Line {0}}"
                                   Classes="FieldLabel Muted"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding MainVm.ActiveToolpathBounds}" Classes="FieldLabel" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding MainVm.ActiveToolpathDepth}" Classes="FieldLabel" Margin="0,4,0,0"/>

                        <Button Content="Unload File"
                                Command="{Binding MainVm.FilesVm.UnloadLoadedFileCommand}"
                                Classes="AppButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,4,0,0"/>
                      </StackPanel>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>
                </StackPanel>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:FilesViewModel}">
                <StackPanel Spacing="8">
                  <controls:SectionCard Title="SELECTED PREVIEW"
                                        IsVisible="{Binding ShowSelectedPreviewCard}">
                    <controls:SectionCard.Body>
                      <controls:FileStateCard Header="{Binding SelectedPreviewHeaderText}"
                                              FileName="{Binding SelectedPreviewFileName}"
                                              SizeText="{Binding SelectedPreviewSizeText}"
                                              LinesText="{Binding SelectedPreviewLinesText}"
                                              StatusText="{Binding SelectedPreviewStatusText}"
                                              StatusBackground="{Binding SelectedPreviewStatusBrush}"
                                              PrimaryActionText="{Binding SelectedPreviewPrimaryActionText}"
                                              PrimaryActionCommand="{Binding SelectedPreviewPrimaryActionCommand}"
                                              EmphasizePrimaryAction="True"/>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>

                  <controls:SectionCard Title="LOADED JOB"
                                        IsVisible="{Binding ShowLoadedJobCard}">
                    <controls:SectionCard.Body>
                      <StackPanel Spacing="6">
                        <controls:StatusPill Text="{Binding LoadedJobFileName}"
                                             PillBackground="{Binding LoadedJobStatusBrush}"/>

                        <controls:TwoColumnInfoGrid>
                          <TextBlock Text="Size" Classes="FieldLabel"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding LoadedJobSizeText}"
                                     Classes="FieldValue"/>

                          <TextBlock Grid.Row="1" Text="Lines" Classes="FieldLabel"/>
                          <TextBlock Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding LoadedJobLinesText}"
                                     Classes="FieldValue"/>
                        </controls:TwoColumnInfoGrid>

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                          <TextBlock Text="Progress" Classes="FieldLabel"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding MainVm.Progress, StringFormat={}{0:F1}%}"
                                     Classes="FieldLabel"/>
                        </Grid>

                        <ProgressBar Value="{Binding MainVm.Progress}" Maximum="100" Height="8" CornerRadius="4"/>

                        <TextBlock Text="{Binding MainVm.CurrentLine, StringFormat=Line {0}}"
                                   Classes="FieldLabel Muted"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding MainVm.ActiveToolpathBounds}" Classes="FieldLabel" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding MainVm.ActiveToolpathDepth}" Classes="FieldLabel" Margin="0,4,0,0"/>

                        <Button Content="Unload File"
                                Command="{Binding UnloadLoadedFileCommand}"
                                Classes="AppButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,4,0,0"/>
                      </StackPanel>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>
                </StackPanel>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:ManualControlViewModel}">
                <Panel/>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:ConnectViewModel}">
                <StackPanel Spacing="8">
                  <controls:SectionCard Title="SESSION">
                    <controls:SectionCard.Body>
                      <StackPanel Spacing="8">
                        <controls:StatusPill Text="{Binding ConnectionHeadline}"
                                             PillBackground="{Binding MainVm.ConnectionStatusBrush}"/>

                        <controls:TwoColumnInfoGrid>
                          <TextBlock Text="USB Port" Classes="FieldLabel"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding SelectedPortDisplay}"
                                     Classes="FieldValue"
                                     TextTrimming="CharacterEllipsis"/>

                          <TextBlock Grid.Row="1" Text="Controller" Classes="FieldLabel"/>
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PicoLinkSummary}" Classes="FieldValue"/>

                          <TextBlock Grid.Row="2" Text="Motion Controller" Classes="FieldLabel"/>
                          <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TeensyLinkSummary}" Classes="FieldValue"/>
                        </controls:TwoColumnInfoGrid>

                        <TextBlock Text="{Binding ConnectionSummary}"
                                   Classes="FieldLabel"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>

                  <controls:SectionCard Title="DEVICE">
                    <controls:SectionCard.Body>
                      <StackPanel Spacing="8">
                        <controls:TwoColumnInfoGrid>
                          <TextBlock Text="Controller FW" Classes="FieldLabel"/>
                          <TextBlock Grid.Column="1" Text="{Binding PicoFirmware}" Classes="FieldValue"/>

                          <TextBlock Grid.Row="1" Text="Motion Controller FW" Classes="FieldLabel"/>
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TeensyFirmware}" Classes="FieldValue"/>
                        </controls:TwoColumnInfoGrid>
                      </StackPanel>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>

                </StackPanel>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <controls:SectionCard Title="SETTINGS"
                                      MinHeight="220">
                  <controls:SectionCard.Body>
                    <Grid RowDefinitions="Auto,8,Auto,8,Auto,*,Auto">
                      <Border Classes="InsetSurface Subtle"
                              Height="NaN"
                              MinHeight="0"
                              Padding="10,8"
                              HorizontalAlignment="Stretch">
                        <TextBlock Text="{Binding SettingsStateText}"
                                   Classes="FieldValue"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                      </Border>

                      <Button Grid.Row="2"
                              Content="Save"
                              Command="{Binding SaveLocalSettingsCommand}"
                              Classes="AppButton Primary"
                              HorizontalAlignment="Stretch"/>

                      <Grid Grid.Row="4"
                            ColumnDefinitions="*,*"
                            ColumnSpacing="8">
                        <Button Content="Revert"
                                Command="{Binding RevertChangesCommand}"
                                Classes="AppButton"
                                HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="1"
                                Content="Load defaults"
                                Command="{Binding LoadDefaultsCommand}"
                                Classes="AppButton"
                                HorizontalAlignment="Stretch"/>
                      </Grid>

                      <Grid Grid.Row="6"
                            ColumnDefinitions="*,*"
                            ColumnSpacing="8">
                        <Button Content="Export"
                                Command="{Binding ExportSettingsCommand}"
                                Classes="AppButton"
                                HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="1"
                                Content="Import"
                                Command="{Binding ImportSettingsCommand}"
                                Classes="AppButton"
                                HorizontalAlignment="Stretch"/>
                      </Grid>
                    </Grid>
                  </controls:SectionCard.Body>
                </controls:SectionCard>
              </DataTemplate>

              <DataTemplate DataType="{x:Type vm:DiagnosticsViewModel}">
                <StackPanel Spacing="8">
                  <controls:SectionCard Title="DIAGNOSTICS">
                    <controls:SectionCard.Body>
                      <StackPanel>
                        <TextBlock Text="{Binding MainVm.StatusMessage}" Classes="FieldValue" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding MainVm.IsStatusError, StringFormat=Active fault: {0}}" Classes="FieldLabel" Margin="0,6,0,0"/>
                      </StackPanel>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>

                  <controls:SectionCard Title="CONSOLE">
                    <controls:SectionCard.Actions>
                      <Button Content="Clear"
                              Command="{Binding ClearLogCommand}"
                              Classes="AppButton"/>
                    </controls:SectionCard.Actions>
                    <controls:SectionCard.Body>
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding LogEntryCount, StringFormat={}{0} entries}" Classes="FieldLabel"/>
                        <Border Background="{DynamicResource ConsoleSurfaceBrush}"
                                CornerRadius="4"
                                Padding="8"
                                MinHeight="320"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                          <TextBox Text="{Binding FullLogText}"
                                   IsReadOnly="True"
                                   AcceptsReturn="True"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   MinHeight="300"/>
                        </Border>
                      </StackPanel>
                    </controls:SectionCard.Body>
                  </controls:SectionCard>
                </StackPanel>
              </DataTemplate>
            </ContentControl.DataTemplates>
          </ContentControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="{DynamicResource HeaderBackgroundBrush}"
            Padding="8"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">

        <StackPanel Orientation="Horizontal" Spacing="4">
          <Button Classes="AppButton Success"
                  Command="{Binding StartCommand}"
                  IsEnabled="{Binding CanStart}"
                  Content="START"/>
          <Button Classes="AppButton Warning"
                  Command="{Binding PauseCommand}"
                  IsEnabled="{Binding CanPause}"
                  Content="PAUSE"/>
          <Button Classes="AppButton Danger"
                  Command="{Binding StopCommand}"
                  IsEnabled="{Binding CanStop}"
                  Content="STOP"/>

          <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,0"/>

          <Button Classes="AppButton"
                  Command="{Binding HomeCommand}"
                  IsEnabled="{Binding CanHome}"
                  Content="HOME ALL"/>

        </StackPanel>

        <Grid Grid.Column="1"
              ColumnDefinitions="Auto,*"
              Margin="8,0"
              ClipToBounds="True">
          <TextBlock Text="Status:"
                     Classes="FieldLabel"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"/>
          <TextBlock Grid.Column="1"
                     Text="{Binding StatusMessage}"
                     Classes="FieldValue"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis"
                     TextWrapping="NoWrap"/>
        </Grid>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="8,0" IsVisible="{Binding IsConnected}">
          <TextBlock Text="Feed:" Classes="FieldLabel" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding FeedRate, StringFormat={}{0:F0}}" Classes="FieldValue" FontWeight="Normal" VerticalAlignment="Center"/>
          <TextBlock Text="mm/min" Classes="FieldLabel" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="8,0" IsVisible="{Binding IsConnected}">
          <TextBlock Text="Temp:" Classes="FieldLabel" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding Temperature, StringFormat={}{0:F1} deg C}" Classes="FieldValue" FontWeight="Normal" VerticalAlignment="Center"/>
        </StackPanel>

        <controls:StatusPill Grid.Column="4"
                             IsVisible="{Binding IsConnected}"
                             Margin="8,0,0,0"
                             Prefix="MOTION:"
                             Text="{Binding MotionStateLabel}"
                             PillBackground="{Binding MotionStateBrush}"
                             LabelForeground="#CCFFFFFF"/>

        <Button Grid.Column="5"
                Classes="AppButton Danger"
                IsEnabled="{Binding IsConnected}"
                FontWeight="Bold"
                Command="{Binding EStopCommand}"
                Content="E-STOP"/>
      </Grid>
    </Border>

  </Grid>
</Window>
