<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PortableCncApp.Controls.SectionHeaderBlock">
  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
    <StackPanel>
      <TextBlock x:Name="TitleText" Classes="PanelTitle"/>
      <TextBlock x:Name="SubtitleText"
                 Classes="FieldLabel"
                 Margin="0,4,0,0"
                 TextWrapping="Wrap"/>
    </StackPanel>

    <ContentControl x:Name="ActionsHost"
                    Grid.Column="1"
                    VerticalAlignment="Center"/>
  </Grid>
</UserControl>
